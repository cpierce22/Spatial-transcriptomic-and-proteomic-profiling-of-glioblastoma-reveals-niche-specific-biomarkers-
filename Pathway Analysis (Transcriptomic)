# --------------------
# 0) Packages
# --------------------
if (!requireNamespace("BiocManager", quietly = TRUE)) install.packages("BiocManager")

cran_pkgs <- c("dplyr","tidyr","ggplot2","stringr","readxl")
for (p in cran_pkgs) if (!requireNamespace(p, quietly=TRUE)) install.packages(p)

bioc_pkgs <- c("NanoStringNCTools","GeomxTools","GeoMxWorkflows","limma")
for (p in bioc_pkgs) if (!requireNamespace(p, quietly=TRUE)) BiocManager::install(p, ask=FALSE)

library(NanoStringNCTools)
library(GeomxTools)
library(GeoMxWorkflows)
library(limma)

library(readxl)
library(dplyr)
library(tidyr)
library(stringr)
library(ggplot2)

# --------------------
# 1) Paths
# --------------------
datadir <- "/Users/sachibadola/Desktop/DSP/Gaur Lab/DSP_RNA"
annotation_file <- file.path(datadir, "Dataset.xlsx")

dcc_files <- list.files(datadir, pattern="\\.dcc$", full.names=TRUE, recursive=TRUE)
pkc_files <- list.files(datadir, pattern="\\.pkc$", full.names=TRUE, recursive=TRUE)

# Remove bad files
exclude_dcc <- c("DSP-1001660011697-F-A01.dcc")
dcc_files <- dcc_files[!basename(dcc_files) %in% exclude_dcc]

# --------------------
# 2) Load RNA Data
# --------------------
rnaData <- suppressWarnings(readNanoStringGeoMxSet(
  dccFiles = dcc_files,
  pkcFiles = pkc_files,
  phenoDataFile = annotation_file,
  phenoDataSheet = "Updated_Annotations for DSP",
  phenoDataDccColName = "Sample_ID",
  analyte = "RNA"
))

# --------------------
# 3) QC + Aggregation
# --------------------
rnaData <- shiftCountsOne(rnaData, useDALogic = TRUE)

rnaData <- setSegmentQCFlags(rnaData, qcCutoffs=list(
  minSegmentReads = 1000,
  percentTrimmed = 80,
  percentStitched = 80,
  percentAligned = 75,
  percentSaturation = 50,
  minNegativeCount = 1,
  maxNTCCount = 9000,
  minNuclei = 20,
  minArea = 1000
))

rnaData <- aggregateCounts(rnaData)

# --------------------
# 4) LOQ Filtering (RNA-specific)
# --------------------
modules <- gsub(".pkc", "", annotation(rnaData))
cutoff <- 2
minLOQ <- 2

LOQ <- data.frame(row.names = colnames(rnaData))

for (mod in modules) {
  vars <- paste0(c("NegGeoMean_", "NegGeoSD_"), mod)

  if (all(vars %in% colnames(pData(rnaData)))) {
    LOQ[, mod] <- pmax(
      minLOQ,
      pData(rnaData)[, vars[1]] *
        (pData(rnaData)[, vars[2]] ^ cutoff)
    )
  }
}

LOQ_mat <- do.call(rbind, lapply(modules, function(mod) {
  idx <- fData(rnaData)$Module == mod
  t(esApply(rnaData[idx, ], 1, function(x) x > LOQ[, mod]))
}))

LOQ_mat <- LOQ_mat[fData(rnaData)$TargetName, ]

fData(rnaData)$DetectedSegments <- rowSums(LOQ_mat, na.rm = TRUE)
fData(rnaData)$DetectionRate <- fData(rnaData)$DetectedSegments / ncol(rnaData)

neg_probes <- unique(
  subset(fData(rnaData), CodeClass == "Negative")$TargetName
)

rnaData <- rnaData[
  fData(rnaData)$DetectionRate >= 0.1 |
    fData(rnaData)$TargetName %in% neg_probes,
]

# --------------------
# 5) Normalization
# --------------------
rnaData <- normalize(
  rnaData,
  norm_method="quant",
  desiredQuantile=0.75,
  toElt="q_norm"
)

expr_matrix <- log2(assayDataElement(rnaData, "q_norm") + 1)

# --------------------
# 6) Sample Metadata
# --------------------
sample_info <- as.data.frame(pData(rnaData))
rownames(sample_info) <- sampleNames(rnaData)

seg_col <- if ("Segment Tags" %in% colnames(sample_info)) "Segment Tags" else "Segment"

sample_info$Segment <- trimws(as.character(sample_info[[seg_col]]))
sample_info$Segment[sample_info$Segment == "Necrosis"] <- "Perinecrotic"
sample_info$Segment[sample_info$Segment == "Vessel"]   <- "Perivascular"
sample_info$Segment <- factor(sample_info$Segment)

sample_info <- sample_info[colnames(expr_matrix), , drop = FALSE]

# --------------------
# 7) limma DE
# --------------------
design <- model.matrix(~ 0 + Segment, data = sample_info)
colnames(design) <- make.names(gsub("^Segment", "", colnames(design)))

fit <- lmFit(expr_matrix, design)

n_C  <- sum(sample_info$Segment == "Cellular tumor")
n_PN <- sum(sample_info$Segment == "Perinecrotic")
n_PV <- sum(sample_info$Segment == "Perivascular")

contrast_matrix <- makeContrasts(
  CellularTumor_vs_Other =
    Cellular.tumor - ((n_PN/(n_PN+n_PV))*Perinecrotic + (n_PV/(n_PN+n_PV))*Perivascular),
  levels = design
)

fit2 <- eBayes(contrasts.fit(fit, contrast_matrix))

# --------------------
# 8) Pathway Analysis (your first script merged in)
# --------------------
df <- read.csv("CellularTumor57.csv", stringsAsFactors = FALSE)

df <- df %>%
  filter(!is.na(Pathways), Pathways != "") %>%
  mutate(Pathways = str_trim(Pathways)) %>%
  separate_rows(Pathways, sep = ";") %>%
  mutate(Pathways = str_trim(Pathways)) %>%
  filter(Pathways != "")

pathway_summary <- df %>%
  group_by(Pathways) %>%
  summarise(mean_logFC = mean(logFC, na.rm = TRUE), .groups="drop")

top_up <- pathway_summary %>%
  arrange(desc(mean_logFC)) %>%
  slice_head(n = 5) %>%
  mutate(Direction = "Up")

top_down <- pathway_summary %>%
  arrange(mean_logFC) %>%
  slice_head(n = 5) %>%
  mutate(Direction = "Down")

bar_data <- bind_rows(top_up, top_down)

ggplot(bar_data, aes(x = reorder(Pathways, mean_logFC), y = mean_logFC, fill = Direction)) +
  geom_col() +
  coord_flip() +
  geom_hline(yintercept = 0, linetype="dashed") +
  scale_fill_manual(values = c("Up"="red","Down"="blue")) +
  theme_minimal() +
  labs(
    title="Top RNA Pathways",
    y="Average log2FC",
    x=NULL
  )

# --------------------
# 9) Membership Plot (unchanged logic)
# --------------------
membership_summary_all <- function(fit_obj, coef_name, membership_map) {
  tt <- topTable(fit_obj, coef = coef_name, number = Inf)
  tt$TargetName <- rownames(tt)

  tt %>%
    left_join(membership_map, by="TargetName") %>%
    separate_rows(Membership, sep="[,;]") %>%
    group_by(Membership) %>%
    summarise(
      Average_logFC = mean(logFC, na.rm=TRUE),
      Count = n(),
      .groups="drop"
    )
}

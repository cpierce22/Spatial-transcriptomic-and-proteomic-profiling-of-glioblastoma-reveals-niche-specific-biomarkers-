library(openxlsx)
library(ggplot2)
library(ggrepel)
Necrosis_Vessel <- read.xlsx("Volcano Plot_Protein.xlsx", sheet = "Necrosis vs Vessel",
startRow = 7)
Necrosis_VesselVolPlot <- ggplot(data = Necrosis_Vessel, aes(x = Log2, y =
`-log10.adjusted.pvalue`)) +
geom_vline(xintercept = c(-1, 1), col = "black", linetype = 'dashed') +
geom_hline(yintercept = -log10(0.05), col = "black", linetype = 'dashed') +
geom_point(aes(colour = ifelse(Adjusted.pvalue <= 0.05 & abs(Log2) >= 1, "black", "grey")),
size = 2) +
scale_colour_manual(values = c("black" = "black", "grey" = "grey")) +
xlim(-3, 3) +
theme_minimal() +
theme(
panel.background = element_rect(fill = "white", colour = NA),
panel.grid.major = element_line(colour = "gray"),
panel.grid.minor = element_line(colour = "gray"),
legend.position = "none"
)
windows()
print(Necrosis_VesselVolPlot)

Necrosis_Tumor <- read.xlsx("Volcano Plot_Protein.xlsx", sheet = "Necrosis vs Tumor",

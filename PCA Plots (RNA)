# =============================================================================
# GeoMx RNA Analysis Workflow (Adapted from Protein Script)
# =============================================================================

# ----------------------------- #
# 1. Setup
# ----------------------------- #

if (!require("BiocManager", quietly = TRUE))
  install.packages("BiocManager")

library(BiocManager)
library(NanoStringNCTools)
library(GeomxTools)
library(GeoMxWorkflows)
library(openxlsx)
library(dplyr)
library(stringr)
library(ggplot2)
library(pheatmap)
library(ComplexHeatmap)
library(RColorBrewer)
library(circlize)
library(matrixStats)
library(DESeq2)

# ----------------------------- #
# 2. File Paths
# ----------------------------- #

datadir <- "/Users/sachibadola/Desktop/DSP/Gaur Lab/DSP_RNA"

dcc_files <- list.files(datadir, pattern = "\\.dcc$",
                        full.names = TRUE, recursive = TRUE)

pkc_files <- list.files(datadir, pattern = "\\.pkc$",
                        full.names = TRUE, recursive = TRUE)

annotation_file <- file.path(datadir, "Dataset.xlsx")

# Remove bad file
dcc_files <- dcc_files[!basename(dcc_files) %in%
                         "DSP-1001660011697-F-A01.dcc"]

# ----------------------------- #
# 3. Load RNA Data
# ----------------------------- #

rnaData <- suppressWarnings(readNanoStringGeoMxSet(
  dccFiles = dcc_files,
  pkcFiles = pkc_files,
  phenoDataFile = annotation_file,
  phenoDataSheet = "Updated_Annotations for DSP",
  phenoDataDccColName = "Sample_ID",
  protocolDataColNames = c("ROI_ID", "Segment Tags"),
  analyte = "RNA"
))

# ----------------------------- #
# 4. QC Filtering
# ----------------------------- #

rnaData <- shiftCountsOne(rnaData, useDALogic = TRUE)

rnaData <- setSegmentQCFlags(rnaData, qcCutoffs = list(
  minSegmentReads = 1000,
  percentTrimmed = 80,
  percentStitched = 80,
  percentAligned = 75,
  percentSaturation = 50,
  minNegativeCount = 1,
  maxNTCCount = 9000,
  minNuclei = 20,
  minArea = 1000
))

# ----------------------------- #
# 5. Aggregate Counts
# ----------------------------- #

rnaData <- aggregateCounts(rnaData)

# ----------------------------- #
# 6. LOQ-Based Filtering (CRITICAL for RNA)
# ----------------------------- #

modules <- gsub(".pkc", "", annotation(rnaData))
cutoff <- 2
minLOQ <- 2

LOQ <- data.frame(row.names = colnames(rnaData))

for (mod in modules) {
  vars <- paste0(c("NegGeoMean_", "NegGeoSD_"), mod)

  if (all(vars %in% colnames(pData(rnaData)))) {
    LOQ[, mod] <- pmax(
      minLOQ,
      pData(rnaData)[, vars[1]] *
        (pData(rnaData)[, vars[2]] ^ cutoff)
    )
  }
}

# Build LOQ matrix
LOQ_mat <- do.call(rbind, lapply(modules, function(mod) {
  idx <- fData(rnaData)$Module == mod
  t(esApply(rnaData[idx, ], 1, function(x) x > LOQ[, mod]))
}))

LOQ_mat <- LOQ_mat[fData(rnaData)$TargetName, ]

# Gene detection
fData(rnaData)$DetectedSegments <- rowSums(LOQ_mat, na.rm = TRUE)
fData(rnaData)$DetectionRate <-
  fData(rnaData)$DetectedSegments / ncol(rnaData)

# Filter genes (RNA-specific)
neg_probes <- unique(
  subset(fData(rnaData), CodeClass == "Negative")$TargetName
)

rnaData <- rnaData[
  fData(rnaData)$DetectionRate >= 0.1 |
    fData(rnaData)$TargetName %in% neg_probes,
]

# ----------------------------- #
# 7. Normalization (RNA-specific)
# ----------------------------- #

rnaData <- normalize(
  rnaData,
  norm_method = "quant",
  desiredQuantile = 0.75,
  toElt = "q_norm"
)

# ----------------------------- #
# 8. DESeq2 Analysis
# ----------------------------- #

count_data <- assayDataElement(rnaData, "q_norm")
col_data <- as.data.frame(pData(rnaData))

dds <- DESeqDataSetFromMatrix(
  countData = round(count_data),
  colData = col_data,
  design = ~ 1
)

# Filter low counts
dds <- dds[rowSums(counts(dds)) >= 10, ]

# rlog transform
rld <- rlog(dds, blind = FALSE)

# ----------------------------- #
# 9. Variance Analysis
# ----------------------------- #

rv <- rowVars(assay(rld))
top_n <- 100
select <- order(rv, decreasing = TRUE)[1:top_n]

rld_sub <- t(assay(rld)[select, ])

# PCA
pca <- prcomp(rld_sub)

percentVar <- pca$sdev^2 / sum(pca$sdev^2)

# ----------------------------- #
# 10. PCA Plot
# ----------------------------- #

pca_df <- as.data.frame(pca$x)
pca_df$Segment <- colData(dds)$Segment
pca_df$SampleID <- colnames(dds)

pca_df$Segment <- as.factor(pca_df$Segment)

# Assign colors
group_colors <- c("purple", "orange", "green")
names(group_colors) <- levels(pca_df$Segment)

pca_df$col <- group_colors[as.character(pca_df$Segment)]

plot(pca_df$PC1, pca_df$PC2,
     xlab = paste0("PC1 (", round(percentVar[1]*100,1), "%)"),
     ylab = paste0("PC2 (", round(percentVar[2]*100,1), "%)"),
     main = paste("RNA PCA"),
     col = pca_df$col,
     pch = 16)

legend("topright",
       legend = levels(pca_df$Segment),
       col = group_colors,
       pch = 16)

# ----------------------------- #
# 11. Heatmap (Top Variable Genes)
# ----------------------------- #

mat <- assay(rld)[select, ]
mat <- t(scale(t(mat)))

pheatmap(mat,
         annotation_col = data.frame(Segment = pca_df$Segment),
         show_rownames = FALSE)

prepare_plot_data <- function(gene_data, region_name) {
  up <- gene_data$up
  down <- gene_data$down
  
  #  Remove unwanted genes
  up <- up[!up$TargetName %in% c("PI3", "GFAP"), ]
  down <- down[!down$TargetName %in% c("PI3", "GFAP"), ]
  
  up$Direction <- "Upregulated"
  down$Direction <- "Downregulated"
  
  combined <- rbind(up, down)
  combined$Region <- region_name
  
  combined$Gene_Label <- paste0(combined$TargetName, "_", region_name)
  return(combined)
}

plot_data <- prepare_plot_data(top_peri, "Perinecrotic vs Perivascular")


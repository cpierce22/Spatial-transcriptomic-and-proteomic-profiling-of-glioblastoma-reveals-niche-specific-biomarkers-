clean_sex <- function(x) {
  x <- trimws(as.character(x))
  x[x %in% c("", "NA", "N/A", "na", "Unknown", "unknown")] <- NA
  x_low <- tolower(x)

  out <- ifelse(
    x_low %in% c("m", "male"), "Male",
    ifelse(
      x_low %in% c("f", "female"), "Female",
      ifelse(is.na(x), NA, "Other/Unknown")
    )
  )

  factor(out, levels = c("Male", "Female", "Other/Unknown"))
}

clean_methylation <- function(x) {
  x <- trimws(as.character(x))
  x[x %in% c("", "NA", "N/A", "na", "Unknown", "unknown")] <- NA
  x_low <- tolower(x)

  out <- ifelse(
    x_low %in% c("methylated", "mgmt methylated", "mgmt-methylated", "yes", "meth", "m"),
    "Methylated",
    ifelse(
      x_low %in% c("unmethylated", "mgmt unmethylated", "mgmt-unmethylated", "no", "unmeth", "u"),
      "Unmethylated",
      NA
    )
  )

  factor(out, levels = c("Methylated", "Unmethylated"))
}

make_age_quartile <- function(x) {
  x_char <- trimws(as.character(x))
  x_char[x_char %in% c("", "NA", "N/A", "na")] <- NA

  age_num <- suppressWarnings(as.numeric(stringr::str_extract(x_char, "\\d+\\.?\\d*")))

  age_bin <- cut(
    age_num,
    breaks = c(49.999, 60, 70, 80, Inf),
    labels = c("50-60", "61-70", "71-80", "81+"),
    right = TRUE
  )

  list(
    age_num = age_num,
    age_quartile = factor(as.character(age_bin), levels = c("50-60", "61-70", "71-80", "81+"))
  )
}

calc_cv <- function(x) {
  x <- x[is.finite(x)]
  if (length(x) < 2) return(NA_real_)

  mu <- mean(x, na.rm = TRUE)
  sigma <- sd(x, na.rm = TRUE)

  if (is.na(mu) || mu == 0 || is.na(sigma)) return(NA_real_)
  sigma / mu
}

prep_heatmap_matrix <- function(feature_ids, eset, elt_name = "log_q") {
  mat <- assayDataElement(eset[feature_ids, ], elt = elt_name)
  mat <- as.matrix(mat)
  mat[is.infinite(mat)] <- NA
  mat <- mat[complete.cases(mat), , drop = FALSE]

  if (nrow(mat) > 0) {
    row_sd <- apply(mat, 1, sd, na.rm = TRUE)
    mat <- mat[!is.na(row_sd) & row_sd > 0, , drop = FALSE]
  }

  mat
}

standardize_segment_labels <- function(x) {
  seg <- trimws(as.character(x))
  seg[seg == "Vessel"] <- "Perivascular"
  seg[seg == "Necrosis"] <- "Perinecrotic"
  factor(seg, levels = c("Cellular tumor", "Perivascular", "Perinecrotic"))
}

build_annotation_colors <- function(annotation_col) {
  gbm_levels <- unique(as.character(annotation_col$GBM_case))
  gbm_levels <- gbm_levels[!is.na(gbm_levels) & gbm_levels != ""]
  gbm_cols <- setNames(grDevices::hcl.colors(length(gbm_levels), palette = "Set 3"), gbm_levels)

  list(
    GBM_case = gbm_cols,
    Segment = c(
      "Cellular tumor" = "purple",
      "Perivascular" = "green",
      "Perinecrotic" = "orange"
    ),
    Brain_region = c(
      "Frontal" = "red",
      "Parietal" = "blue",
      "Temporal" = "yellow"
    ),
    Methylation = c(
      "Methylated" = "#1b9e77",
      "Unmethylated" = "#d95f02"
    ),
    Age_quartile = c(
      "50-60" = "#c6dbef",
      "61-70" = "#9ecae1",
      "71-80" = "#6baed6",
      "81+" = "#2171b5"
    ),
    Sex = c(
      "Male" = "#4C78A8",
      "Female" = "#E45756",
      "Other/Unknown" = "grey60"
    ),
    AgeGroup = c(
      "50-60" = "pink",
      "60-70" = "cyan",
      "70-80" = "gold",
      "80+" = "brown"
    )
  )
}

# ============================================================
# Section I. Proteomic heatmaps
# ============================================================

# -------------------- File discovery --------------------
dcc_files <- list.files(
  path = proteomics_datadir,
  pattern = "\\.dcc$",
  full.names = TRUE,
  recursive = TRUE
)

pkc_files <- list.files(
  path = proteomics_datadir,
  pattern = "\\.pkc$",
  full.names = TRUE,
  recursive = TRUE
)

dcc_files <- dcc_files[!basename(dcc_files) %in% exclude_dcc]

if (length(dcc_files) == 0) stop("No DCC files found after exclusion.")
if (length(pkc_files) == 0) stop("No PKC files found.")
if (!file.exists(proteomics_annotation_file)) {
  stop("Annotation file not found: ", proteomics_annotation_file)
}

# -------------------- Read GeoMx protein data --------------------
protein_data <- suppressWarnings(
  readNanoStringGeoMxSet(
    dccFiles = dcc_files,
    pkcFiles = pkc_files,
    phenoDataFile = proteomics_annotation_file,
    phenoDataSheet = proteomics_annotation_sheet,
    phenoDataDccColName = "Sample_ID",
    protocolDataColNames = c("ROI_ID", "Segment Tags"),
    analyte = "Protein"
  )
)

# -------------------- QC flagging --------------------
protein_data <- setSegmentQCFlags(
  protein_data,
  qcCutoffs = list(
    percentSaturation = 45,
    minSegmentReads = 1000,
    percentAligned = 80,
    minNegativeCount = 10,
    maxNTCCount = 60,
    minNuclei = 16000,
    minArea = 20
  )
)

# -------------------- Normalization --------------------
protein_data <- normalize(
  protein_data,
  norm_method = "quant",
  desiredQuantile = 0.75,
  toElt = "q_norm"
)

if (!"q_norm" %in% assayDataElementNames(protein_data)) {
  stop("Normalization failed: 'q_norm' assay not found.")
}

assayDataElement(protein_data, "log_q") <- assayDataApply(
  protein_data,
  MARGIN = 2,
  FUN = log,
  base = 2,
  elt = "q_norm"
)

# -------------------- Remove low-saturation ROIs --------------------
qc_flags_df <- as.data.frame(protocolData(protein_data)[["QCFlags"]])
if (!"LowSaturation" %in% colnames(qc_flags_df)) {
  stop("QCFlags does not contain 'LowSaturation'.")
}

low_saturation_idx <- which(qc_flags_df[, "LowSaturation"])
if (length(low_saturation_idx) > 0) {
  protein_data <- protein_data[, -low_saturation_idx]
  message("Removed ", length(low_saturation_idx), " low-saturation ROI(s).")
} else {
  message("No low-saturation ROIs removed.")
}

# -------------------- Metadata curation --------------------
pd <- as.data.frame(Biobase::pData(protein_data), stringsAsFactors = FALSE)
colnames(pd) <- trimws(colnames(pd))

required_cols <- c("Segment", "Brain_region", "Scan_ID", "Age", "Gender", "Methylation status")
missing_cols <- setdiff(required_cols, colnames(pd))
if (length(missing_cols) > 0) {
  stop("Missing required metadata column(s): ", paste(missing_cols, collapse = ", "))
}

pd$Segment <- standardize_segment_labels(pd$Segment)
pd$Brain_region <- factor(trimws(as.character(pd$Brain_region)),
                          levels = c("Frontal", "Parietal", "Temporal"))
pd$GBM_case <- gsub("_", "", trimws(as.character(pd$Scan_ID)))
pd$Methylation_status_clean <- clean_methylation(pd[["Methylation status"]])

age_info <- make_age_quartile(pd[["Age"]])
pd$Age_numeric <- age_info$age_num
pd$Age_quartile <- age_info$age_quartile
pd$Sex_clean <- clean_sex(pd[["Gender"]])

if (is.null(rownames(pd)) || any(is.na(rownames(pd))) || any(rownames(pd) == "")) {
  if (nrow(pd) == ncol(protein_data)) {
    rownames(pd) <- colnames(protein_data)
  } else {
    stop("pData row names are missing and cannot be inferred reliably.")
  }
}

if (!all(colnames(protein_data) %in% rownames(pd))) {
  if (nrow(pd) == ncol(protein_data)) {
    warning("Resetting metadata row names to match protein_data columns.")
    rownames(pd) <- colnames(protein_data)
  } else {
    stop("Cannot align metadata rows to protein_data columns.")
  }
}

Biobase::pData(protein_data) <- pd

annotation_col_protein <- data.frame(
  GBM_case = pd$GBM_case,
  Segment = pd$Segment,
  Brain_region = pd$Brain_region,
  Methylation = pd$Methylation_status_clean,
  Age_quartile = pd$Age_quartile,
  Sex = pd$Sex_clean,
  row.names = rownames(pd),
  stringsAsFactors = FALSE
)
annotation_col_protein <- annotation_col_protein[colnames(protein_data), , drop = FALSE]

annotation_col_protein$Methylation <- factor(annotation_col_protein$Methylation,
                                             levels = c("Methylated", "Unmethylated"))
annotation_col_protein$Age_quartile <- factor(annotation_col_protein$Age_quartile,
                                              levels = c("50-60", "61-70", "71-80", "81+"))
annotation_col_protein$Sex <- factor(annotation_col_protein$Sex,
                                     levels = c("Male", "Female", "Other/Unknown"))

annotation_colors_protein <- build_annotation_colors(annotation_col_protein)

# -------------------- CV ranking --------------------
cv_dat_protein <- assayDataApply(protein_data, elt = "log_q", MARGIN = 1, FUN = calc_cv)
cv_dat_protein <- cv_dat_protein[!is.na(cv_dat_protein) & is.finite(cv_dat_protein)]
cv_sorted_protein <- sort(cv_dat_protein, decreasing = TRUE)

if (length(cv_sorted_protein) < 5) {
  stop("Too few proteins with valid CV values for heatmap generation.")
}

get_top_percent_ids <- function(cv_sorted, pct) {
  n_total <- length(cv_sorted)
  n_keep <- max(ceiling(n_total * pct), 2)
  names(cv_sorted)[seq_len(min(n_keep, n_total))]
}

plot_top_percent_protein_heatmap <- function(
  pct,
  cv_sorted,
  eset,
  annotation_col,
  annotation_colors,
  output_dir
) {
  feature_ids <- get_top_percent_ids(cv_sorted, pct)
  mat_top <- prep_heatmap_matrix(feature_ids, eset, elt_name = "log_q")
  pct_num <- round(pct * 100)

  if (nrow(mat_top) < 2 || ncol(mat_top) < 2) {
    warning(
      "Skipping top ", pct_num, "% proteomic heatmap: matrix is ",
      nrow(mat_top), " x ", ncol(mat_top)
    )
    return(invisible(NULL))
  }

  annotation_use <- annotation_col[colnames(mat_top), , drop = FALSE]
  if (!identical(rownames(annotation_use), colnames(mat_top))) {
    stop("Annotation rows do not match proteomic heatmap columns.")
  }

  out_file <- file.path(
    output_dir,
    paste0("GBM_top", pct_num, "pct_variable_proteins_heatmap.pdf")
  )

  pdf(out_file, width = 12, height = max(7, 0.28 * nrow(mat_top) + 5))
  on.exit(dev.off(), add = TRUE)

  pheatmap(
    mat_top,
    scale = "row",
    show_rownames = TRUE,
    show_colnames = FALSE,
    fontsize_row = 4,
    fontsize_col = 7,
    fontsize = 8,
    border_color = NA,
    clustering_method = "average",
    clustering_distance_rows = "correlation",
    clustering_distance_cols = "correlation",
    color = colorRampPalette(c("purple3", "black", "yellow2"))(120),
    breaks = seq(-3, 3, length.out = 121),
    annotation_col = annotation_use,
    annotation_colors = annotation_colors[c("GBM_case", "Segment", "Brain_region", "Methylation", "Age_quartile", "Sex")],
    main = paste0(
      "Unsupervised clustering (top ", pct_num,
      "% variable proteins; n = ", nrow(mat_top), ")"
    )
  )

  message("Saved: ", out_file)
  message("Top ", pct_num, "% retained after cleanup: ", nrow(mat_top), " proteins")
  invisible(mat_top)
}


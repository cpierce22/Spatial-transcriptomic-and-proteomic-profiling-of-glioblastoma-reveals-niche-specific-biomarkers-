# ============================================================
# Section II. Transcriptomic heatmap
# ============================================================
# Expected input:
#   target_demoData : ExpressionSet-like object containing a log-transformed
#                     assay element named 'log_q' and sample metadata in pData.
#
# Required pData columns:
#   Segment, Brain_region, and optionally AgeGroup.
# ============================================================

if (!exists("target_demoData")) {
  message("RNA section skipped: object 'target_demoData' was not found in the environment.")
} else {
  if (!inherits(target_demoData, c("ExpressionSet", "NanoStringGeoMxSet"))) {
    stop("'target_demoData' must be an ExpressionSet- or NanoStringGeoMxSet-like object.")
  }

  if (!"log_q" %in% assayDataElementNames(target_demoData)) {
    stop("RNA section requires assay element 'log_q' in target_demoData.")
  }

  pd_rna <- as.data.frame(Biobase::pData(target_demoData), stringsAsFactors = FALSE)
  colnames(pd_rna) <- trimws(colnames(pd_rna))

  required_rna_cols <- c("Segment", "Brain_region")
  missing_rna_cols <- setdiff(required_rna_cols, colnames(pd_rna))
  if (length(missing_rna_cols) > 0) {
    stop("Missing required RNA metadata column(s): ", paste(missing_rna_cols, collapse = ", "))
  }

  pd_rna$Segment <- standardize_segment_labels(pd_rna$Segment)
  pd_rna$Brain_region <- factor(trimws(as.character(pd_rna$Brain_region)),
                                levels = c("Frontal", "Parietal", "Temporal"))

  if ("Scan_ID" %in% colnames(pd_rna)) {
    pd_rna$GBM_case <- gsub("_", "", trimws(as.character(pd_rna$Scan_ID)))
  } else {
    pd_rna$GBM_case <- NA_character_
  }

  if ("AgeGroup" %in% colnames(pd_rna)) {
    pd_rna$AgeGroup <- factor(trimws(as.character(pd_rna$AgeGroup)),
                              levels = c("50-60", "60-70", "70-80", "80+"))
  }

  if (is.null(rownames(pd_rna)) || any(is.na(rownames(pd_rna))) || any(rownames(pd_rna) == "")) {
    if (nrow(pd_rna) == ncol(target_demoData)) {
      rownames(pd_rna) <- colnames(target_demoData)
    } else {
      stop("RNA metadata row names are missing and cannot be inferred reliably.")
    }
  }

  if (!all(colnames(target_demoData) %in% rownames(pd_rna))) {
    if (nrow(pd_rna) == ncol(target_demoData)) {
      warning("Resetting RNA metadata row names to match target_demoData columns.")
      rownames(pd_rna) <- colnames(target_demoData)
    } else {
      stop("Cannot align RNA metadata rows to target_demoData columns.")
    }
  }

  Biobase::pData(target_demoData) <- pd_rna

  cv_dat_rna <- assayDataApply(target_demoData, elt = "log_q", MARGIN = 1, FUN = calc_cv)
  cv_dat_rna <- cv_dat_rna[!is.na(cv_dat_rna) & is.finite(cv_dat_rna)]

  if (length(cv_dat_rna) < 10) {
    stop("Too few transcriptomic features with valid CV values for heatmap generation.")
  }

  # Retain the intent of the original draft by selecting the most variable
  # transcriptomic features using a high-CV tail threshold.
  goi <- names(cv_dat_rna)[cv_dat_rna > quantile(cv_dat_rna, 0.997, na.rm = TRUE)]

  if (length(goi) < 2) {
    stop("RNA GOI selection yielded fewer than 2 features; adjust the quantile threshold.")
  }

  mat_rna <- prep_heatmap_matrix(goi, target_demoData, elt_name = "log_q")

  if (nrow(mat_rna) < 2 || ncol(mat_rna) < 2) {
    stop("RNA heatmap matrix is too small after cleanup.")
  }

  annotation_vars_rna <- c("Segment", "Brain_region")
  if ("AgeGroup" %in% colnames(pd_rna)) {
    annotation_vars_rna <- c(annotation_vars_rna, "AgeGroup")
  }

  annotation_col_rna <- pd_rna[colnames(mat_rna), annotation_vars_rna, drop = FALSE]
  annotation_colors_rna <- build_annotation_colors(
    data.frame(GBM_case = pd_rna$GBM_case,
               Segment = pd_rna$Segment,
               Brain_region = pd_rna$Brain_region,
               Methylation = factor(NA, levels = c("Methylated", "Unmethylated")),
               Age_quartile = factor(NA, levels = c("50-60", "61-70", "71-80", "81+")),
               Sex = factor(NA, levels = c("Male", "Female", "Other/Unknown")))
  )
  annotation_colors_rna <- annotation_colors_rna[names(annotation_col_rna)]

  n_rows <- nrow(mat_rna)
  n_cols <- ncol(mat_rna)
  width_in <- max(10, 0.35 * n_cols + 6)
  height_in <- max(10, 0.35 * n_rows + 6)

  out_file_rna <- file.path(rna_output_dir, "GBM_RNA_high_variability_heatmap.png")

  png(filename = out_file_rna, width = width_in, height = height_in, units = "in", res = 300)
  on.exit(dev.off(), add = TRUE)

  pheatmap(
    mat_rna,
    scale = "row",
    show_rownames = TRUE,
    show_colnames = FALSE,
    border_color = NA,
    clustering_method = "average",
    clustering_distance_rows = "correlation",
    clustering_distance_cols = "correlation",
    breaks = seq(-3, 3, length.out = 121),
    color = colorRampPalette(c("purple3", "black", "yellow2"))(120),
    annotation_col = annotation_col_rna,
    annotation_colors = annotation_colors_rna,
    cellwidth = NA,
    cellheight = ifelse(n_rows < 50, 12, NA),
    main = paste0("Unsupervised clustering of highly variable RNA features (n = ", n_rows, ")")
  )

  dev.off()
  message("Saved RNA heatmap: ", out_file_rna)

  cat("\n--- RNA annotation summary ---\n")
  print(table(pd_rna$Segment, useNA = "ifany"))
  print(table(pd_rna$Brain_region, useNA = "ifany"))
  if ("AgeGroup" %in% colnames(pd_rna)) {
    print(table(pd_rna$AgeGroup, useNA = "ifany"))
  }
}


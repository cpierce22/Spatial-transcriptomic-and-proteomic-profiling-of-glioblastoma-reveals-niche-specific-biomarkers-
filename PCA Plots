  for (pkg in pkgs) {
    if (!requireNamespace(pkg, quietly = TRUE)) {
      if (bioc) {
        BiocManager::install(pkg, ask = FALSE, update = FALSE)
      } else {
        install.packages(pkg)
      }
    }
  }
}

install_if_missing(cran_packages, bioc = FALSE)
install_if_missing(bioc_packages, bioc = TRUE)


#COX MODELING
# -------------------- Libraries --------------------
# -------------------- Libraries --------------------
library(GeomxTools)
library(survival)
library(dplyr)
library(ggplot2)
library(forcats)

# -------------------- Normalize + log2 --------------------
target_demoData <- normalize(
  target_demoData,
  norm_method = "quant",
  desiredQuantile = 0.75,
  toElt = "q_norm"
)

log_q <- log2(assayDataElement(target_demoData, "q_norm") + 1)
log_q[is.infinite(log_q)] <- NA
assayDataElement(target_demoData, "log_q") <- log_q

# -------------------- Expression + metadata --------------------
log_expr <- assayDataElement(target_demoData, "log_q")
meta <- as.data.frame(pData(target_demoData))

# -------------------- Clean metadata --------------------
meta$Overall_survival_months <- as.numeric(trimws(as.character(meta$Overall_survival_months)))

seg_col <- if ("Segment Tags" %in% colnames(meta)) "Segment Tags" else "Segment"

meta[[seg_col]] <- trimws(as.character(meta[[seg_col]]))

# relabel once
meta[[seg_col]][meta[[seg_col]] == "Necrosis"] <- "Perinecrotic"
meta[[seg_col]][meta[[seg_col]] == "Vessel"]   <- "Perivascular"

segments <- c("Cellular tumor", "Perivascular", "Perinecrotic")

cox_by_segment <- list()

# -------------------- Cox per segment --------------------
for (seg in segments) {
  cat("\nSegment:", seg, "\n")
  
  idx <- which(meta[[seg_col]] == seg)
  
  seg_expr <- log_expr[, idx, drop = FALSE]
  seg_time <- meta$Overall_survival_months[idx]
  
  # survival status (replace if real event exists)
  seg_status <- rep(1, length(seg_time))
  
  valid <- !is.na(seg_time)
  
  if (sum(valid) < 5) next
  
  surv_obj <- Surv(seg_time[valid], seg_status[valid])
  seg_expr <- seg_expr[, valid, drop = FALSE]
  
  seg_results <- lapply(rownames(seg_expr), function(rna) {
    expr <- as.numeric(seg_expr[rna, ])
    
    if (all(is.na(expr)) || sd(expr, na.rm = TRUE) == 0) return(NULL)
    
    model <- tryCatch(coxph(surv_obj ~ expr), error = function(e) NULL)
    if (is.null(model)) return(NULL)
    
    s <- summary(model)
    
    beta <- coef(model)[1]
    HR <- exp(beta)
    
    data.frame(
      RNA = rna,
      beta = beta,
      HR = HR,
      p.value = s$coefficients[1, "Pr(>|z|)"],
      z = s$coefficients[1, "z"],
      Segment = seg,
      stringsAsFactors = FALSE
    )
  })
  
  seg_results <- Filter(Negate(is.null), seg_results)
  
  if (length(seg_results) > 0) {
    seg_df <- bind_rows(seg_results)
    seg_df$FDR <- p.adjust(seg_df$p.value, method = "BH")
    cox_by_segment[[seg]] <- seg_df
  }
}


all_cox <- bind_rows(cox_by_segment)

forest_df <- all_cox %>%
  filter(
    is.finite(HR),
    HR > 1,
    p.value < 0.05
  ) %>%
  group_by(Segment) %>%
  arrange(desc(HR), .by_group = TRUE) %>%
  slice_head(n = 10) %>%
  ungroup() %>%
  mutate(
    label = paste0(RNA, " (FDR=", signif(FDR, 2), ")")
  )

p_forest <- ggplot(forest_df, aes(x = HR, y = forcats::fct_reorder(label, HR), color = Segment)) +
  geom_vline(xintercept = 1, linetype = "dashed", color = "gray40") +
  geom_errorbarh(aes(xmin = HR * 0.7, xmax = HR * 1.3), height = 0.2) +
  geom_point(size = 3) +
  facet_wrap(~Segment, scales = "free_y") +
  scale_color_manual(values = c(
    "Cellular tumor" = "purple",
    "Perivascular"   = "green",
    "Perinecrotic"   = "orange"
  )) +
  theme_minimal() +
  labs(
    title = "Top Prognostic RNAs by Segment",
    x = "Hazard Ratio",
    y = "RNA"
  )

ggsave("~/Desktop/Cox_Forest.png", p_forest, width = 11, height = 6, dpi = 300)







# --------------------
# 0) Packages
# --------------------
if (!requireNamespace("BiocManager", quietly = TRUE)) install.packages("BiocManager")

cran_pkgs <- c("dplyr","tidyr","ggplot2","stringr","readxl")
for (p in cran_pkgs) if (!requireNamespace(p, quietly=TRUE)) install.packages(p)


library(tidyverse)

# Step 1: Load the data
df <- read.csv("CellularTumor57.csv", stringsAsFactors = FALSE)

# Step 2: Clean and split the Pathways column
df$Pathways <- trimws(df$Pathways)
df <- df[!is.na(df$Pathways) & df$Pathways != "", ]

# Step 3: Expand multiple pathways into separate rows
df_expanded <- df %>%
  separate_rows(Pathways, sep = ";") %>%
  mutate(Pathways = trimws(Pathways)) %>%
  filter(Pathways != "")

# Step 4: Calculate average logFC per pathway
pathway_summary <- df_expanded %>%
  group_by(Pathways) %>%
  summarise(mean_logFC = mean(logFC, na.rm = TRUE)) %>%
  ungroup()

# Step 5: Get top 5 upregulated and downregulated pathways
top_up <- pathway_summary %>%
  arrange(desc(mean_logFC)) %>%
  slice_head(n = 5) %>%
  mutate(Direction = "Up-regulated")

top_down <- pathway_summary %>%
  arrange(mean_logFC) %>%
  slice_head(n = 5) %>%
  mutate(Direction = "Down-regulated")

# Step 6: Combine and plot
bar_data <- bind_rows(top_up, top_down)

ggplot(bar_data, aes(x = reorder(Pathways, mean_logFC), y = mean_logFC, fill = Direction)) +
  geom_col() +
  coord_flip() +
  scale_fill_manual(values = c("Up-regulated" = "red", "Down-regulated" = "blue")) +
  geom_hline(yintercept = 0, linetype = "dashed") +
  labs(
    title = "Top Up- and Down-Regulated Pathways in Cellular Tumor",
    x = NULL,
    y = "Average Log₂(Fold Change)"
  ) +
  theme_minimal(base_size = 14)



# drop genes with low counts
keep <- rowSums(exprs(proteinData)) >= 10
proteinData <- proteinData[keep,]

# check the new dimensions
dim(proteinData)


proteinData_normalized <- normalize(proteinData)

# Log2 transformation
log2_data <- log2(exprs(proteinData_normalized) + 1)

if (!requireNamespace("DESeq2", quietly = TRUE)) {
  install.packages("BiocManager")
  BiocManager::install("DESeq2")
}
library(DESeq2)

# Example assuming `exprs(proteinData)` gives a raw count matrix
count_data <- exprs(proteinData)
col_data <- as.data.frame(pData(proteinData))  # Phenotype data

# Ensure columns and rows are consistent
dds <- DESeqDataSetFromMatrix(
  countData = count_data,
  colData = col_data,
  design = ~ 1  # Update design formula based on your metadata
)

# drop genes with low counts
keep <- rowSums(counts(dds)) >= 10
dds <- dds[keep,]

# check the new dimensions
dim(dds)

rld <- rlog(dds, blind = FALSE)

# check first few rows
head(assay(rld))

# calculate gene expression level variance between samples
var <- rev(rowVars(assay(rld))[order(rowVars(assay(rld)))])

# reset plotting window to 1 row vs 1 columns
par(mfrow=c(1,1))

# plot variance for genes accross samples
plot(var,
     las = 1,
     main="Sample gene expression variance",
     xlab = "Gene", ylab = "Variance")

# add vertical lines at specific gene number indexes
abline(v=1000, col="red")
abline(v=500, col="green")
abline(v=250, col="blue")

# modify variable feature number to be used in PCA and hierarchical clustering based on no. of most variable features
var_feature_n <- 100

# calculate the row variance
rv <- rowVars(assay(rld))

# order variance by size and select top 250 with most variance
select <- order(rv, decreasing = TRUE)[1:100]

# subset rlog values for genes with top variance ranks
rld_sub <- assay(rld)[select, ]

# transpose the matrix (rows to columns and columns to rows)
rld_sub <- t(rld_sub)

# run principal components analysis
pca <- prcomp(rld_sub)

# extract the variance explained by each PC
percentVar <- pca$sdev^2/sum(pca$sdev^2)

# subset for first 5 elemets
percentVar <- percentVar[1:5]

# give the string names
names(percentVar) <- c("PC1", "PC2", "PC3", "PC4", "PC5")

# plot variance for top 10 PCs
barplot(percentVar, col = "indianred", las = 1, ylab = "% Variance", cex.lab = 1.2)

# construct data frame w/ PC loadings and add sample labels
pca <- prcomp(t(assay(rld)), center = TRUE, scale. = TRUE)
Segment <- colData(dds)$Segment
if (is.null(Segment)) {
  stop("The column 'Segment' is missing in colData(dds).")
}

pca_df <- as.data.frame(pca$x)  # Principal component scores
pca_df$Segment <- colData(dds)$Segment # Treatment groups
pca_df$Scan_ids <- colnames(dds)  # Sample IDs

pca_df$Segment <- as.factor(pca_df$Segment)
pca_df$col <- as.numeric(pca_df$Segment)

plot(pca_df[, 1], pca_df[, 2],
     xlab = paste0("PC1 (", round(percentVar[1] * 100, 1), "% variance)"),
     ylab = paste0("PC2 (", round(percentVar[2] * 100, 1), "% variance)"),
     main = paste0("PC1 vs PC2 for ", var_feature_n, " most variable genes"),
     pch = 16, cex = 1.35, cex.lab = 1.3, cex.axis = 1.15, las = 1,
     panel.first = grid(),
     col = pca_df$col)
text(pca_df[, 1], pca_df[, 2], labels = pca_df$sample_ids, cex = 0.6, pos = 4)


# add sample names to data points
text((pca_df[, 2])~(pca_df[, 1]), labels = pca_df$tx.group, cex=0.6, font=2, pos=4)

color_mapping <- data.frame(
  Group = levels(pca_df$Segment),
  Color = unique(pca_df$col)
)
print(color_mapping)


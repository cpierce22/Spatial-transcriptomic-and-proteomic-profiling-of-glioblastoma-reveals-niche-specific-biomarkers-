prepare_top_gene_plot_data <- function(gene_data, region_name) {
  
  if (!all(c("up", "down") %in% names(gene_data))) {
    stop("gene_data must contain $up and $down dataframes.")
  }
  
  up <- gene_data$up
  down <- gene_data$down
  
  up$Direction <- "Upregulated"
  down$Direction <- "Downregulated"
  
  combined <- bind_rows(up, down) %>%
    mutate(
      Region = region_name,
      Gene_Label = paste0(TargetName, "_", region_name)
    )
  
  return(combined)
}

plot_transcriptomic_top_genes <- function(
    top_necrosis,
    top_cellular,
    top_vessel,
    top_n = 10,
    output_file = file.path(path.expand(output_dir), "RNA_TopGenes_ByRegion.pdf")
) {
  
  plot_data <- bind_rows(
    prepare_top_gene_plot_data(top_necrosis, "Perinecrotic"),
    prepare_top_gene_plot_data(top_cellular, "Cellular Tumor"),
    prepare_top_gene_plot_data(top_vessel, "Perivascular")
  )
  
  plot_data <- plot_data %>%
    filter(!is.na(TargetName), !is.na(logFC)) %>%
    arrange(Region, Direction, desc(abs(logFC)))
  
  plot_data$Gene_Label <- factor(
    plot_data$Gene_Label,
    levels = unique(plot_data$Gene_Label)
  )
  
  plot_data <- bind_rows(top_up, top_down) %>%
    mutate(
      Label = paste0(
        Pathways,
        " (n=", n_features,
        ", FDR=", signif(pathway_adj_p_value, 2),
        ")"
      )
    )
  
  p <- ggplot(plot_data, aes(x = Gene_Label, y = logFC, fill = Direction)) +
    geom_col(show.legend = TRUE) +
    facet_wrap(~Region, scales = "free_y", ncol = 1) +
    coord_flip() +
    scale_fill_manual(values = c(
      "Upregulated" = "firebrick",
      "Downregulated" = "steelblue"
    )) +
    geom_hline(yintercept = 0, linetype = "dashed") +
    scale_x_discrete(labels = function(x) sub("_[^_]+$", "", x)) +
    labs(
      title = paste0("Transcriptomics: Top ", top_n, " Up- and Downregulated Genes by Tumor Region"),
      x = "Gene",
      y = "log fold change"
    ) +
    theme_minimal(base_size = 12) +
    theme(
      strip.text = element_text(size = 12, face = "bold"),
      axis.text.y = element_text(size = 9, face = "bold"),
      legend.position = "top",
      plot.title = element_text(face = "bold")
    )
  
  ggsave(
    filename = output_file,
    plot = p,
    device = "pdf",
    width = 12,
    height = 18,
    units = "in",
    bg = "white",
    useDingbats = FALSE
  )
  
  return(p)
}


# ============================================================
# PART 1: SIMPLE PATHWAY SUMMARY FROM CSV WITH PATHWAY FDR
# ============================================================

plot_pathway_summary_from_csv <- function(
    csv_file,
    region_name,
    top_n = 5,
    output_file = NULL
) {
  
  df <- read.csv(csv_file, stringsAsFactors = FALSE)
  
  if (!all(c("Pathways", "logFC") %in% colnames(df))) {
    stop("CSV must contain columns named 'Pathways' and 'logFC'.")
  }
  
  df_expanded <- df %>%
    mutate(Pathways = trimws(Pathways)) %>%
    filter(!is.na(Pathways), Pathways != "") %>%
    separate_rows(Pathways, sep = ";") %>%
    mutate(Pathways = trimws(Pathways)) %>%
    filter(Pathways != "", !is.na(logFC))
  
  pathway_summary <- df_expanded %>%
    group_by(Pathways) %>%
    summarise(
      mean_logFC = mean(logFC, na.rm = TRUE),
      median_logFC = median(logFC, na.rm = TRUE),
      n_features = n(),
      pathway_p_value = ifelse(
        n_features >= 2,
        t.test(logFC, mu = 0)$p.value,
        NA_real_
      ),
      .groups = "drop"
    ) %>%
    mutate(
      pathway_adj_p_value = p.adjust(pathway_p_value, method = "BH")
    )
  
  top_up <- pathway_summary %>%
    arrange(desc(mean_logFC)) %>%
    slice_head(n = top_n) %>%
    mutate(Direction = "Upregulated")
  
  top_down <- pathway_summary %>%
    arrange(mean_logFC) %>%
    slice_head(n = top_n) %>%
    mutate(Direction = "Downregulated")
  
  plot_data <- bind_rows(top_up, top_down) %>%
    mutate(
      FDR_label = ifelse(
        is.na(pathway_adj_p_value),
        "FDR=NA",
        paste0("FDR=", signif(pathway_adj_p_value, 2))
      ),
      Label = paste0(
        Pathways,
        " (n=", n_features,
        ", ", FDR_label,
        ")"
      )
    )
  
  p <- ggplot(
    plot_data,
    aes(x = reorder(Label, mean_logFC), y = mean_logFC, fill = Direction)
  ) +
    geom_col() +
    coord_flip() +
    geom_hline(yintercept = 0, linetype = "dashed") +
    scale_fill_manual(values = c(
      "Upregulated" = "firebrick",
      "Downregulated" = "steelblue"
    )) +
    labs(
      title = paste0("Top Up- and Downregulated Pathways: ", region_name),
      subtitle = "Pathway FDR calculated from one-sample t-tests of protein log2FC values against zero",
      x = NULL,
      y = "Average log2 fold change"
    ) +
    theme_minimal(base_size = 12) +
    theme(
      plot.title = element_text(face = "bold"),
      plot.subtitle = element_text(size = 9),
      legend.position = "top",
      panel.grid.major.y = element_blank()
    )
  
  if (!is.null(output_file)) {
    ggsave(
      filename = output_file,
      plot = p,
      device = "pdf",
      width = 11,
      height = 6,
      units = "in",
      bg = "white",
      useDingbats = FALSE
    )
  }
  
  return(list(
    plot = p,
    pathway_summary = pathway_summary,
    plot_data = plot_data
  ))
}

